#include <bits/stdc++.h>
using namespace std;

const int K = 450;

void solve() {
    int n, q;
    cin >> n >> q;

    vector<int> f(n, -1);
    vector<int> g(n, -1);

    // Numbers as square or sum of two squares
    for (int a = 1; a * a < n; a++) {

        f[a * a] = 1;

        for (int b = a; a * a + b * b < n; b++) {
            f[a * a + b * b] = 2;
        }
    }

    // Numbers as difference of squares
    for (int b = 1; b * b < n; b++) {

        for (int a = b; a * a - b * b < n; a++) {

            int v = a * a - b * b;

            if (g[v] == -1) {
                g[v] = b * b;
            }
        }
    }

    while (q--) {

        int a, b;
        cin >> a >> b;

        int ans = 4;

        for (int d = -K; d <= K; d++) {

            int x = a + abs(d) * d;

            if (x <= 0 || x > n) continue;

            int ta = min(x, b);
            int tb = max(x, b);

            int v = tb - ta;
            int cur = 4;

            if (g[v] > 0 && g[v] <= max(n - tb, ta - 1)) {
                cur = 2;
            }

            if (f[v] > 0) {
                cur = f[v];
            }

            if (d != 0) {
                cur++;
            }

            ans = min(ans, cur);
        }

        cout << ans << '\n';
    }
}

int main() {

    ios::sync_with_stdio(false);
    cin.tie(nullptr);

    int t;
    cin >> t;

    while (t--) {
        solve();
    }

    return 0;
}
